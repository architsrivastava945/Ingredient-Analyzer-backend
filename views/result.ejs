<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Analysis Result — Ingredient Analyzer</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Nunito', sans-serif; background: #fdfdfd; color: #1a2744; }
  .container { max-width: 480px; margin: 0 auto; padding-bottom: 40px; }

  header {
    background: #1a2744; color: #fff;
    padding: 30px 20px 40px; text-align: center;
    border-radius: 0 0 30px 30px; position: relative;
  }
  .back-btn {
    position: absolute; left: 20px; top: 30px;
    color: #fff; text-decoration: none; font-size: 20px;
  }
  header h2 { font-size: 16px; font-weight: 800; margin-bottom: 16px; }

  /* Score circle — color changes by verdict */
  .score-container {
    width: 110px; height: 110px; border-radius: 50%;
    border: 7px solid var(--score-color, #e05555);
    margin: 0 auto 10px; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    background: #fff; color: #1a2744;
  }
  .score-val   { font-size: 30px; font-weight: 900; }
  .score-label { font-size: 9px;  font-weight: 800; text-transform: uppercase; color: #666; }

  .verdict-text { font-size: 13px; opacity: 0.85; font-weight: 700; }

  /* Summary card */
  .summary-card {
    background: #fff; margin: -20px 20px 20px;
    padding: 18px; border-radius: 15px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.07);
    text-align: center;
  }
  .status-tag {
    display: inline-block; padding: 4px 14px;
    border-radius: 20px; font-size: 12px; font-weight: 800; margin-bottom: 10px;
  }
  .tag-clean    { background: #f0fff4; color: #276749; }
  .tag-moderate { background: #fff9db; color: #856404; }
  .tag-unhealthy{ background: #fff1f0; color: #cf1322; }
  .tag-hazard   { background: #2d1b1b; color: #ff4d4f; }

  .stats-row {
    display: flex; justify-content: center;
    gap: 20px; margin-top: 12px;
  }
  .stat { text-align: center; }
  .stat-val  { font-size: 20px; font-weight: 900; color: #1a2744; }
  .stat-label{ font-size: 10px; font-weight: 700; color: #999; }

  /* Section headers */
  .list-section { padding: 0 20px; margin-bottom: 8px; }
  .section-title {
    font-size: 14px; font-weight: 800; margin: 20px 0 12px;
    display: flex; align-items: center; gap: 8px;
  }

  /* Ingredient cards */
  .ing-card {
    background: #fff; border-radius: 12px; padding: 13px 15px;
    margin-bottom: 10px; display: flex; align-items: center;
    gap: 14px; border-left: 5px solid #eee;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .ing-card.hazard   { border-left-color: #ff4d4f; }
  .ing-card.unhealthy{ border-left-color: #fa8c16; }
  .ing-card.moderate { border-left-color: #fadb14; }
  .ing-card.healthy  { border-left-color: #52c41a; }
  .ing-card.neutral  { border-left-color: #d9d9d9; }

  .ing-icon {
    width: 38px; height: 38px; border-radius: 10px;
    background: #f8f9fa; display: flex;
    align-items: center; justify-content: center; font-size: 17px; flex-shrink: 0;
  }
  .ing-info { flex: 1; min-width: 0; }
  .ing-name { font-weight: 800; font-size: 13px; margin-bottom: 3px; text-transform: capitalize; }
  .ing-desc { font-size: 11px; color: #777; line-height: 1.4; }

  .risk-badge {
    font-size: 9px; font-weight: 800; padding: 2px 7px;
    border-radius: 4px; white-space: nowrap; flex-shrink: 0;
    align-self: flex-start;
  }
  .badge-hazard    { background: #2d1b1b; color: #ff4d4f; }
  .badge-unhealthy { background: #fff2e8; color: #d4380d; }
  .badge-moderate  { background: #fffbe6; color: #d48806; }
  .badge-healthy   { background: #f6ffed; color: #389e0d; }
  .badge-neutral   { background: #f5f5f5; color: #595959; }

  /* Unmatched section */
  .unmatched-wrap {
    padding: 0 20px; margin-bottom: 20px;
  }
  .unmatched-list {
    display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px;
  }
  .unmatched-chip {
    background: #f0f0f0; color: #666;
    font-size: 10px; font-weight: 700;
    padding: 4px 10px; border-radius: 20px;
    text-transform: capitalize;
  }

  /* Scan again button */
  .actions { padding: 20px; }
  .btn-scan-again {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%; padding: 14px; border-radius: 12px;
    background: #1a2744; color: #fff;
    border: none; font-family: inherit;
    font-weight: 800; font-size: 14px; cursor: pointer;
    text-decoration: none; transition: 0.2s;
  }
  .btn-scan-again:active { opacity: 0.85; }
</style>
</head>
<body>

<%
  // Helper: pick score circle color by verdict
  const scoreColors = {
    'Clean':     '#52c41a',
    'Moderate':  '#fadb14',
    'Unhealthy': '#fa8c16',
    'Hazard':    '#ff4d4f'
  };
  const scoreColor = scoreColors[result.verdict] || '#e05555';

  // Helper: icon for each verdict
  const verdictIcons = {
    'Hazard':    'fa-skull-crossbones',
    'Unhealthy': 'fa-triangle-exclamation',
    'Moderate':  'fa-droplet',
    'Healthy':   'fa-leaf',
    'Neutral':   'fa-circle-check'
  };
%>

<div class="container">
  <header>
    <a href="/" class="back-btn"><i class="fa-solid fa-chevron-left"></i></a>
    <h2>Analysis Report</h2>

    <div class="score-container" style="--score-color: <%= scoreColor %>">
      <span class="score-val"><%= result.score %></span>
      <span class="score-label">Safety Score</span>
    </div>
    <p class="verdict-text"><%= result.verdict %> Product</p>
  </header>

  <!-- Summary card -->
  <div class="summary-card">
    <% if (result.verdict === 'Clean') { %>
      <span class="status-tag tag-clean"><i class="fa-solid fa-circle-check"></i> Clean</span>
      <p style="font-size:13px;color:#555;">This product has predominantly natural and safe ingredients.</p>
    <% } else if (result.verdict === 'Moderate') { %>
      <span class="status-tag tag-moderate"><i class="fa-solid fa-triangle-exclamation"></i> Moderate Caution</span>
      <p style="font-size:13px;color:#555;">Contains some processed elements. Consume in moderation.</p>
    <% } else if (result.verdict === 'Unhealthy') { %>
      <span class="status-tag tag-unhealthy"><i class="fa-solid fa-circle-xmark"></i> Unhealthy</span>
      <p style="font-size:13px;color:#555;">Contains several concerning additives. Limit consumption.</p>
    <% } else { %>
      <span class="status-tag tag-hazard"><i class="fa-solid fa-skull-crossbones"></i> Hazard</span>
      <p style="font-size:13px;color:#555;">Contains high-risk ingredients. Avoid if possible.</p>
    <% } %>

    <div class="stats-row">
      <div class="stat">
        <div class="stat-val"><%= result.matchedCount %></div>
        <div class="stat-label">Identified</div>
      </div>
      <div class="stat">
        <div class="stat-val"><%= result.hazardIngredients.length + result.unhealthyIngredients.length %></div>
        <div class="stat-label">Flagged</div>
      </div>
      <div class="stat">
        <div class="stat-val"><%= result.healthyIngredients.length %></div>
        <div class="stat-label">Safe</div>
      </div>
      <div class="stat">
        <div class="stat-val"><%= result.score %>/100</div>
        <div class="stat-label">Score</div>
      </div>
    </div>
  </div>

  <!-- Hazard ingredients -->
  <% if (result.hazardIngredients.length > 0) { %>
  <div class="list-section">
    <div class="section-title">
      <i class="fa-solid fa-skull-crossbones" style="color:#ff4d4f"></i> Hazardous Ingredients
    </div>
    <% result.hazardIngredients.forEach(ing => { %>
    <div class="ing-card hazard">
      <div class="ing-icon"><i class="fa-solid fa-skull-crossbones" style="color:#ff4d4f"></i></div>
      <div class="ing-info">
        <div class="ing-name"><%= ing.name %></div>
        <div class="ing-desc"><%= ing.description %></div>
      </div>
      <span class="risk-badge badge-hazard">HAZARD</span>
    </div>
    <% }) %>
  </div>
  <% } %>

  <!-- Unhealthy ingredients -->
  <% if (result.unhealthyIngredients.length > 0) { %>
  <div class="list-section">
    <div class="section-title">
      <i class="fa-solid fa-triangle-exclamation" style="color:#fa8c16"></i> Unhealthy Ingredients
    </div>
    <% result.unhealthyIngredients.forEach(ing => { %>
    <div class="ing-card unhealthy">
      <div class="ing-icon"><i class="fa-solid fa-triangle-exclamation" style="color:#fa8c16"></i></div>
      <div class="ing-info">
        <div class="ing-name"><%= ing.name %></div>
        <div class="ing-desc"><%= ing.description %></div>
      </div>
      <span class="risk-badge badge-unhealthy">UNHEALTHY</span>
    </div>
    <% }) %>
  </div>
  <% } %>

  <!-- Moderate ingredients -->
  <% if (result.moderateIngredients.length > 0) { %>
  <div class="list-section">
    <div class="section-title">
      <i class="fa-solid fa-droplet" style="color:#fadb14"></i> Moderate Ingredients
    </div>
    <% result.moderateIngredients.forEach(ing => { %>
    <div class="ing-card moderate">
      <div class="ing-icon"><i class="fa-solid fa-droplet" style="color:#d4b106"></i></div>
      <div class="ing-info">
        <div class="ing-name"><%= ing.name %></div>
        <div class="ing-desc"><%= ing.description %></div>
      </div>
      <span class="risk-badge badge-moderate">MODERATE</span>
    </div>
    <% }) %>
  </div>
  <% } %>

  <!-- Healthy/Neutral ingredients -->
  <% if (result.healthyIngredients.length > 0) { %>
  <div class="list-section">
    <div class="section-title">
      <i class="fa-solid fa-leaf" style="color:#52c41a"></i> Safe Ingredients
    </div>
    <% result.healthyIngredients.forEach(ing => { %>
    <div class="ing-card <%= ing.verdict.toLowerCase() %>">
      <div class="ing-icon"><i class="fa-solid fa-leaf" style="color:#52c41a"></i></div>
      <div class="ing-info">
        <div class="ing-name"><%= ing.name %></div>
        <div class="ing-desc"><%= ing.description %></div>
      </div>
      <span class="risk-badge badge-healthy"><%= ing.verdict.toUpperCase() %></span>
    </div>
    <% }) %>
  </div>
  <% } %>

  <!-- Unrecognized ingredients -->
  <% if (result.unmatched.length > 0) { %>
  <div class="unmatched-wrap">
    <div class="section-title" style="margin-top:20px">
      <i class="fa-solid fa-question" style="color:#999"></i>
      Unrecognized (<%= result.unmatched.length %>)
    </div>
    <div class="unmatched-list">
      <% result.unmatched.forEach(u => { %>
        <span class="unmatched-chip"><%= u %></span>
      <% }) %>
    </div>
  </div>
  <% } %>

  <div class="actions">
    <a href="/" class="btn-scan-again">
      <i class="fa-solid fa-camera"></i> Scan Another Product
    </a>
  </div>

</div>
</body>
</html>